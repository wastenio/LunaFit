# PostgreSQL (use a URL com pool no app e a URL direta nas migrations)
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require&connect_timeout=20&pool_timeout=30"
DATABASE_URL_UNPOOLED="postgresql://usuario:senha@host/banco?sslmode=require&connect_timeout=20&pool_timeout=30"

# Admin
ADMIN_PASSWORD="troque-esta-senha"
AUTH_SECRET="gere-uma-string-longa-e-aleatoria"

# Login Google de clientes
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Exemplo local: http://127.0.0.1:3210
AUTH_URL=""

# Emails transacionais de clientes (Resend)
RESEND_API_KEY=""
# Exemplo apos verificar seu dominio: LunaFit <contato@seudominio.com>
EMAIL_FROM=""

# Pagamentos Mercado Pago Payment Brick
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=""
NEXT_PUBLIC_APP_URL=""

# Frete e entrega via Melhor Envio
# Sandbox: https://sandbox.melhorenvio.com.br
# Producao: https://www.melhorenvio.com.br
MELHOR_ENVIO_BASE_URL="https://sandbox.melhorenvio.com.br"
MELHOR_ENVIO_ACCESS_TOKEN=""
MELHOR_ENVIO_ORIGIN_POSTAL_CODE=""
# Exemplo: LunaFit (contato@seudominio.com)
MELHOR_ENVIO_USER_AGENT=""
# Opcional: IDs de servicos, como "1,2,18"
MELHOR_ENVIO_SERVICES=""
# Secret do aplicativo Melhor Envio para validar X-ME-Signature
MELHOR_ENVIO_WEBHOOK_SECRET=""

# Loja publica
NEXT_PUBLIC_STORE_NAME="LunaFit"
NEXT_PUBLIC_STORE_INSTAGRAM_URL=""
NEXT_PUBLIC_STORE_WHATSAPP_NUMBER=""
NEXT_PUBLIC_STORE_EMAIL=""
